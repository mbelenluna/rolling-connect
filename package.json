{
  "name": "rolling-connect",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "clean:client-requests": "node scripts/clean-client-requests.js",
    "backfill:client-ids": "ts-node -P scripts/tsconfig.json scripts/backfill-client-ids.ts",
    "reset-test-users": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/reset-test-users.ts"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.87.0",
    "@livekit/components-react": "^2.0.0",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "ably": "^2.19.0",
    "bcryptjs": "^2.4.3",
    "gocardless-nodejs": "^8.0.2",
    "jspdf": "^4.2.0",
    "livekit-client": "^2.0.0",
    "lucide-react": "^0.460.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "next": "14.2.35",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "twilio": "^5.12.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
