# Database
DATABASE_URL="postgresql://user:password@localhost:5432/rolling_connect"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
# NEXTAUTH_DEBUG="1"  # Enable NextAuth debug logs (dev/staging only)
# ADMIN_DIAG_EMAILS="admin@example.com"  # Comma-separated emails allowed to access /api/admin/diag/auth

# Google OAuth (clients only) - create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="xxx"

# SendGrid for welcome emails (https://sendgrid.com)
# Create API key with Mail Send > Full Access. Verify sender at sendgrid.com/settings/sender_auth
SENDGRID_API_KEY="SG.xxx"

# Optional: Daily.co for video/audio calls (https://dashboard.daily.co)
# DAILY_API_KEY="xxx"
# DAILY_DOMAIN="your-subdomain"  # MUST match your Daily account. Find at dashboard.daily.co → Developers or Room settings. Use only the subdomain (e.g. "mycompany" for mycompany.daily.co)

# Azure Speech Services for AI interpretation (https://portal.azure.com → Create Speech resource)
# AZURE_SPEECH_KEY="xxx"
# AZURE_SPEECH_REGION="eastus"  # Region where your Speech resource is deployed

# GoCardless billing (Redirect Flow + webhooks)
# Required for billing: create at https://manage.gocardless.com (live) or https://manage-sandbox.gocardless.com (sandbox)
GOCARDLESS_ACCESS_TOKEN="live_xxx"  # or sandbox_xxx for testing
GOCARDLESS_ENV="sandbox"  # or "live" for production
GOCARDLESS_WEBHOOK_ENDPOINT_SECRET="whsec_xxx"  # From Developer → Webhooks → Create endpoint → Copy secret
# Webhook URL to configure in GoCardless: https://your-domain.com/api/webhooks/gocardless
